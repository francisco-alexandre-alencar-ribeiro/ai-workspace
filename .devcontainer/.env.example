# ── Ollama ────────────────────────────────────────────────────────────────────
OLLAMA_PORT=11434
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_HOST=http://ollama:11434

# ── Open WebUI ────────────────────────────────────────────────────────────────
WEBUI_PORT=3000

# ── DevContainer — resource limits ────────────────────────────────────────────
DEVCONTAINER_MEMORY_LIMIT=8g
DEVCONTAINER_MEMORY_RESERVE=512m
DEVCONTAINER_CPU_LIMIT=4
DEVCONTAINER_CPU_RESERVE=0.5

# ── Node.js (Dockerfile build arg) ────────────────────────────────────────────
NODE_MAJOR=20

# ── SSH Agent ─────────────────────────────────────────────────────────────────
# Preenchido automaticamente pelo shell do host; sobrescreva apenas se necessário
# SSH_AUTH_SOCK=/run/user/1000/keyring/ssh
